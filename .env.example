 # SLIPA — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/slipa

# JWT — minimum 32 random characters
JWT_SECRET=replace_with_32_plus_random_characters_here

# AES-256 encryption key for bank account numbers — exactly 64 hex characters (32 bytes)
BANK_ENCRYPTION_KEY=replace_with_64_character_hex_string_here

# Gemini AI (Google) — required for the AI conversation engine
GEMINI_API_KEY=your-gemini-api-key-here

# File storage for generated PDFs (S3-compatible or Cloudinary)
STORAGE_BUCKET_NAME=slipa-pdfs
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=                   # leave blank for AWS S3; set for Cloudinary or R2

# App base URL — used for PDF download links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Transactional email — optional in v1.0 (Resend or Postmark)
EMAIL_API_KEY=
EMAIL_FROM=invoices@yourdomain.com
